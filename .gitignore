# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
dist/
build/
.uv/
uv.lock

# ─── Zenoh ───────────────────────────────────────────────────
# zenoh 세션 임시 파일
*.zenoh/

# ─── Frontend ────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.pnpm-store/

# ─── OS ──────────────────────────────────────────────────────
# Windows
Thumbs.db
desktop.ini

# macOS
.DS_Store
.AppleDouble

# Linux
*~

# ─── IDE ─────────────────────────────────────────────────────
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.swp
*.swo

# ─── Env ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Weights ───────────────────────────────────────────────────
*.pt
*.pth

# ─── Convex decomposition collision meshes ─────────────────────
# onshape-to-robot 가 자동 생성하는 정밀 collision STL (각 visual 부품을 convex
# hull 여러 개로 분해). PyBullet self-collision check 같은 자리에서 사용.
# 우리 코드는 IK / FK / 시각화만 — collision 미사용. URDF 의 <collision> tag
# 자체를 제거 (so101_6dof URDF 처리 단계) 했으므로 자산 자체가 불필요.
# ts_flake d2lrobot 리포에서 필요 시 재 다운로드 가능 (so101_6dof_plan.md §3 참조).
robot/*/urdf/meshes/convex_decomposition/

# ─── TSDF scans / meshes (per-instance runtime artifact) ───────
# 대용량 + 머신별 캡처. 캘 결과 (robot/instances/<id>/calibration/) 와는 다름.
robot/instances/*/scans/
robot/instances/*/meshes/

# ─── Self-play logs / learning state (legacy, self-play 폐기됨) ──
# attempt jsonl + bin_offsets.json (closed-loop 학습 누적). 머신별 + 누적
# 데이터라 푸시/공유 대상 아님. self-play 자체는 deprecated.
robot/instances/*/logs/

# ─── Calibration history (per-machine rollback backups) ────────
# .history/<timestamp>_<tag>/ — pre-commit / pre-restore snapshot 누적.
# PC 머신 한 곳에서만 쌓임. 분산 머신은 live npz 만 git pull 로 동기.
robot/instances/*/calibration/.history/

# ─── Storage layer (docs/storage_layer.md) ─────────────────────
# DB (backend/storage/horibot.db) 는 git tracked — 다른 PC 에서 같은 캘 데이터로 테스트.
# blobs/ (대용량 mesh / scan binary) 는 ignored — 머신별 + 큰 자료.
# SQLite WAL/SHM 임시 파일도 ignored.
backend/storage/blobs/
backend/storage/*.db-wal
backend/storage/*.db-shm
backend/storage/*.db-journal

# ─── Alembic autogenerate scratch DB ───────────────────────────
# backend/.alembic_autogen.db — `alembic revision --autogenerate` 가 ORM
# metadata 와 비교할 scratch SQLite. 운영 DB (backend/storage/horibot.db) 와 별개.
# alembic.ini::sqlalchemy.url 자리.
backend/.alembic_autogen.db
backend/.alembic_autogen.db-*